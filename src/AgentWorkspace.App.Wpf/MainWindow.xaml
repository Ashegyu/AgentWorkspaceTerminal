<Window x:Class="AgentWorkspace.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:cp="clr-namespace:AgentWorkspace.App.Wpf.CommandPalette"
        xmlns:at="clr-namespace:AgentWorkspace.App.Wpf.AgentTrace"
        Title="Agent Workspace Terminal"
        Height="600"
        Width="980"
        Background="#0b0e14"
        UseLayoutRounding="True">
    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl+Shift" Key="P" Command="{x:Static ApplicationCommands.Find}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Find}" Executed="OnPaletteShortcut"/>
    </Window.CommandBindings>
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush"      Color="#0b0e14"/>
        <SolidColorBrush x:Key="ChromeBrush"  Color="#11141b"/>
        <SolidColorBrush x:Key="TextBrush"    Color="#cbd2dc"/>
        <SolidColorBrush x:Key="MutedBrush"   Color="#6b7280"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#79c0ff"/>
    </Window.Resources>

    <Grid>
        <!-- Inner content rows. The palette overlay sits on top via Panel.ZIndex. -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top chrome strip — workspace name, version tag, and active provider badges. -->
        <Border Grid.Row="0"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="#1f2530"
                BorderThickness="0,0,0,1"
                Padding="10,5">
            <DockPanel>
                <!-- Left: workspace identity -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Agent Workspace"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="12"/>
                    <TextBlock Text="  ·  MVP-2"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="12"/>
                </StackPanel>
                <!-- Right: active provider badges (updated from code-behind as panes open/close).
                     Per-pane badges inside the SPA are deferred to P3 (require JS/SPA changes). -->
                <StackPanel x:Name="ProviderBadgePanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <TextBlock x:Name="ProviderBadgeText"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!--
            Row 1 splits horizontally: terminal SPA on the left, optional AgentTrace
            panel on the right. The trace column has Width=0 by default and is expanded
            to ~420px on first agent session start (see ShowAgentTrace in code-behind).
        -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="TraceCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- WebView2 host that owns the xterm SPA. -->
            <wv2:WebView2 x:Name="WebView"
                          Grid.Column="0"
                          DefaultBackgroundColor="#0b0e14"/>

            <!-- Agent trace timeline; collapsed (zero-width) until an agent session starts. -->
            <Border Grid.Column="1"
                    Background="{StaticResource ChromeBrush}"
                    BorderBrush="#1f2530"
                    BorderThickness="1,0,0,0">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Background="#11141b"
                            BorderBrush="#1f2530"
                            BorderThickness="0,0,0,1"
                            Padding="10,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="에이전트 트레이스"
                                       Foreground="{StaticResource TextBrush}"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    x:Name="CloseTraceButton"
                                    Content="✕"
                                    Foreground="{StaticResource MutedBrush}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,2"
                                    Cursor="Hand"
                                    Click="OnCloseTraceClicked"
                                    ToolTip="트레이스 패널 숨기기"/>
                        </Grid>
                    </Border>

                    <at:AgentTraceControl x:Name="TracePanel"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Bottom event-timeline placeholder; populated in MVP-6. -->
        <Border Grid.Row="2"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="#1f2530"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="Initialising…"
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11"/>
                <TextBlock Grid.Column="1"
                           Text="Ctrl+Shift+P"
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11"/>
            </Grid>
        </Border>

        <!--
            Palette is hosted in a Popup (its own native HWND) so it renders above the
            WebView2 native HWND. A sibling WPF child with Panel.ZIndex would be obscured
            by WebView2's airspace regardless of Z-order.
            PlacementTarget + Palette dimensions are wired in code-behind so they track
            the Window's ActualWidth/ActualHeight reliably across resize.
        -->
        <Popup x:Name="PalettePopup"
               Placement="Relative"
               AllowsTransparency="True"
               StaysOpen="True"
               Focusable="True">
            <cp:CommandPalette x:Name="Palette"/>
        </Popup>
    </Grid>
</Window>
