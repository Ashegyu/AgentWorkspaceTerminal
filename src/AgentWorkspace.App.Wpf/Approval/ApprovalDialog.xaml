<Window x:Class="AgentWorkspace.App.Wpf.Approval.ApprovalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Approve Actions" Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="The agent requests approval for the following actions:"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <ItemsControl Grid.Row="1"
                      x:Name="ActionsList"
                      Margin="0,0,0,16">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDDDDD" BorderThickness="1"
                            CornerRadius="4" Padding="8" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       FontWeight="SemiBold"
                                       Text="{Binding TypeLabel}"/>

                            <Border Grid.Row="0" Grid.Column="1"
                                    Background="{Binding RiskBrush}"
                                    CornerRadius="3" Padding="6,1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding RiskLabel}"
                                           Foreground="White"
                                           FontSize="10" FontWeight="Bold"/>
                            </Border>

                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                       TextWrapping="Wrap" Foreground="#444444"
                                       Margin="0,4,0,0" Text="{Binding Description}"/>

                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                       TextWrapping="Wrap" Foreground="#666666"
                                       FontStyle="Italic" FontSize="11"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding ShowReason,
                                                            Converter={StaticResource BoolToVis}}"
                                       Text="{Binding Reason, StringFormat=Reason: {0}}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Grid.Row="2"
                   Text="Approve all listed actions?"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Deny All" IsCancel="True" Width="90"
                    Margin="0,0,8,0" Click="OnDeny"/>
            <Button Content="Approve All" IsDefault="True" Width="100"
                    Click="OnApprove"/>
        </StackPanel>
    </Grid>
</Window>
