<UserControl x:Class="AgentWorkspace.App.Wpf.AgentTrace.AgentTraceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AgentWorkspace.App.Wpf.AgentTrace"
             Background="#0b0e14">

    <UserControl.Resources>
        <!-- Shared brushes -->
        <SolidColorBrush x:Key="TextBrush"    Color="#cbd2dc"/>
        <SolidColorBrush x:Key="MutedBrush"   Color="#6b7280"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#79c0ff"/>
        <SolidColorBrush x:Key="ErrorBrush"   Color="#f97583"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#56d364"/>
        <SolidColorBrush x:Key="ActionBrush"  Color="#d2a8ff"/>

        <!-- Assistant / user message -->
        <DataTemplate DataType="{x:Type local:MessageEventVm}">
            <Border Padding="10,6" Margin="0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Role}"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="11"
                               VerticalAlignment="Top"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Text}"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Tool / action request (collapsible) -->
        <DataTemplate DataType="{x:Type local:ActionRequestVm}">
            <Border Margin="0,1">
                <Expander IsExpanded="{Binding IsExpanded}"
                          Background="#11141b"
                          Foreground="{StaticResource ActionBrush}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙ "
                                       Foreground="{StaticResource ActionBrush}"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="{StaticResource ActionBrush}"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="11"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border Padding="16,4,4,4">
                        <TextBlock Text="{Binding ActionType}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="11"/>
                    </Border>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- Session done -->
        <DataTemplate DataType="{x:Type local:DoneEventVm}">
            <Border Padding="10,6" Margin="0,1" Background="#0d1117">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✓ done"
                               Foreground="{StaticResource SuccessBrush}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="11"/>
                    <TextBlock Text="{Binding Summary, StringFormat='  {0}'}"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="400"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Error -->
        <DataTemplate DataType="{x:Type local:ErrorEventVm}">
            <Border Padding="10,6" Margin="0,1" Background="#1a0d0d">
                <TextBlock Text="{Binding Message, StringFormat='✗ {0}'}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="Scroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Events}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"/>
    </ScrollViewer>

</UserControl>
